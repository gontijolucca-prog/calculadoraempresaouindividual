rules_version = '2';

// Regras conservadoras para a coleĂ§Ă£o `updates` (lista de updates devâ†”cliente).
//
// Estado actual: a app nĂ£o tem autenticaĂ§Ă£o real (LoginPage Ă© mock). Por isso,
// as regras abaixo aplicam restriĂ§Ăµes estruturais em vez de identidade:
//
//  - read: qualquer pessoa pode ler (a lista Ă© mostrada na UI).
//  - create: qualquer pessoa pode criar, MAS sĂ³ com a forma esperada e tamanho razoĂ¡vel.
//  - update: sĂ³ permitido alternar os flags `atualizado` e `aprovado` (toggle workflow);
//    o `text` e `createdAt` ficam imutĂ¡veis para evitar reescritas oportunistas.
//  - delete: sĂ³ permitido em items jĂ¡ marcados como `aprovado:true` (housekeeping
//    seguro). Items pendentes ou sĂ³ atualizados nĂ£o podem ser apagados â€” protege
//    contra "cliente apaga update do dev por engano".
//
// Quando integrares Firebase Auth, restringir create/update/delete a:
//   request.auth != null && request.auth.token.admin == true
// E adicionar regras especĂ­ficas para outros caminhos (clientProfile, fichaState, etc.).

service cloud.firestore {
  match /databases/{database}/documents {

    match /updates/{docId} {
      allow read: if true;

      allow create: if isValidUpdateCreate(request.resource.data);

      allow update: if isToggleOnly(resource.data, request.resource.data);

      allow delete: if resource.data.aprovado == true;
    }

    // Bloquear tudo o resto explicitamente atĂ© existir auth real.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidUpdateCreate(data) {
  return data.keys().hasOnly(['text', 'atualizado', 'aprovado', 'createdAt'])
      && data.text is string
      && data.text.size() > 0
      && data.text.size() < 1000
      && data.atualizado is bool
      && data.aprovado is bool;
}

function isToggleOnly(before, after) {
  // Permite alterar sĂ³ `atualizado` e `aprovado`. Texto e createdAt imutĂ¡veis.
  return after.text == before.text
      && after.createdAt == before.createdAt
      && after.atualizado is bool
      && after.aprovado is bool;
}
