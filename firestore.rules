rules_version = '2';

// Regras conservadoras para a coleção `updates` (lista de updates dev↔cliente).
//
// Estado actual: a app não tem autenticação real (LoginPage é mock). Por isso,
// as regras abaixo aplicam restrições estruturais em vez de identidade:
//
//  - read: qualquer pessoa pode ler (a lista é mostrada na UI).
//  - create: qualquer pessoa pode criar, MAS só com a forma esperada e tamanho razoável.
//  - update: só permitido alternar os flags `atualizado` e `aprovado` (toggle workflow);
//    o `text` e `createdAt` ficam imutáveis para evitar reescritas oportunistas.
//  - delete: só permitido em items já marcados como `aprovado:true` (housekeeping
//    seguro). Items pendentes ou só atualizados não podem ser apagados — protege
//    contra "cliente apaga update do dev por engano".
//
// Quando integrares Firebase Auth, restringir create/update/delete a:
//   request.auth != null && request.auth.token.admin == true
// E adicionar regras específicas para outros caminhos (clientProfile, fichaState, etc.).

service cloud.firestore {
  match /databases/{database}/documents {

    match /updates/{docId} {
      allow read: if true;

      allow create: if isValidUpdateCreate(request.resource.data);

      allow update: if isToggleOnly(resource.data, request.resource.data);

      allow delete: if resource.data.aprovado == true;
    }

    // Registry de empresas por escritório (multi-tenant via officeId = NIF do escritório).
    // Ainda sem auth: validamos estruturalmente que o payload é um array de empresas.
    // Quando integrares Firebase Auth, restringir a request.auth.uid == officeId.
    match /empresas/{officeId} {
      allow read: if true;
      allow write: if isValidEmpresasPayload(request.resource.data);
    }

    // Bloquear tudo o resto explicitamente até existir auth real.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function isValidUpdateCreate(data) {
  // `autor` é opcional (compatibilidade com versões antigas da app que ainda
  // criam sem assinatura), mas quando vem tem de ser um nome curto.
  return data.keys().hasOnly(['text', 'atualizado', 'aprovado', 'createdAt', 'autor'])
      && data.text is string
      && data.text.size() > 0
      && data.text.size() < 1000
      && data.atualizado is bool
      && data.aprovado is bool
      && (!('autor' in data) || (data.autor is string && data.autor.size() > 0 && data.autor.size() < 100));
}

function isToggleOnly(before, after) {
  // Permite alterar só os flags e as respectivas assinaturas (quem marcou +
  // quando). Tudo o resto — text, createdAt, autor — fica imutável por exclusão:
  // qualquer chave fora desta lista no diff chumba a regra.
  return after.diff(before).affectedKeys().hasOnly(
        ['atualizado', 'aprovado', 'atualizadoPor', 'atualizadoEm', 'aprovadoPor', 'aprovadoEm'])
      && after.atualizado is bool
      && after.aprovado is bool
      && (!('atualizadoPor' in after) || (after.atualizadoPor is string && after.atualizadoPor.size() < 100))
      && (!('aprovadoPor' in after) || (after.aprovadoPor is string && after.aprovadoPor.size() < 100))
      && (!('atualizadoEm' in after) || after.atualizadoEm is number)
      && (!('aprovadoEm' in after) || after.aprovadoEm is number);
}

function isValidEmpresasPayload(data) {
  // Estrutura esperada: { list: [...], updatedAt: <number> }.
  // Limite estrutural para evitar payloads absurdos.
  return data.keys().hasOnly(['list', 'updatedAt'])
      && data.list is list
      && data.list.size() < 500
      && data.updatedAt is number;
}
